# ── Backend (.env inside /backend) ──────────────────────────────────────────
# Get your free key at: https://financialmodelingprep.com
FMP_API_KEY=your_fmp_api_key_here

# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use for highlights generation
# Update to latest available model (e.g. claude-haiku-4-5, claude-sonnet-4-6)
CLAUDE_MODEL=claude-haiku-4-5

# Frontend URL (for CORS) — change in production
FRONTEND_URL=http://localhost:5173


# ── Frontend (.env inside /frontend) ────────────────────────────────────────
# Leave empty for local dev (Vite proxy handles it)
# Set to your Render backend URL in production:
# VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=
